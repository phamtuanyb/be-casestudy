# --- Local / Dev ---
DATABASE_URI=file:./mkt.db
PAYLOAD_SECRET=thay-bang-chuoi-ngau-nhien-that-dai
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Origin được phép gọi API (FE). Nhiều origin phân tách dấu phẩy.
CORS_ORIGINS=http://localhost:3001
CSRF_ORIGINS=http://localhost:3001

# Webhook báo FE revalidate khi publish nội dung
FE_REVALIDATE_URL=http://localhost:3001/api/revalidate
REVALIDATE_SECRET=thay-bang-chuoi-bi-mat-chung-voi-FE

# Email thông báo khi có lead (để trống RESEND_API_KEY ở dev → email log ra console)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=onboarding@resend.dev   # prod: dùng email thuộc domain đã verify ở Resend
RESEND_FROM_NAME=MKT Showcase
LEAD_NOTIFY_EMAIL=sale@mktsoftware.vn

